#!/usr/bin/env bash
set -e

# Auto-format staged Rust files before commit
if command -v cargo >/dev/null 2>&1; then
    cargo fmt --all
    git add -u
fi

if command -v ruff >/dev/null 2>&1; then
    ruff format .
    git add -u
fi

if [ -f scripts/update_readme_scoreboard.py ]; then
    python3 scripts/update_readme_scoreboard.py || true
    git add README.md
fi
