{
  "hooks": {
    "BeforeTool": [
      {
        "hooks": [
          {
            "command": ".gemini/hooks/orbit-learning-reminder",
            "name": "orbit-learning-reminder",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "AfterTool": [
      {
        "matcher": "replace|write_file",
        "hooks": [
          {
            "type": "command",
            "command": "codegraph mark-dirty",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "codegraph sync-if-dirty"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "orbit": {
      "args": [
        "mcp",
        "serve"
      ],
      "command": "orbit"
    },
    "codegraph": {
      "command": "codegraph",
      "args": ["serve", "--mcp"]
    }
  }
}
